model Campaign {
    id           String    @id @default(uuid())
    title        String
    description  String?
    goalAmount   Float?
    raisedAmount Float?    @default(0)
    startDate    DateTime
    endDate      DateTime?
    categoryId   String?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    donations          Donation[]
    recurringDonations RecurringDonation[]
    updates            CampaignUpdate[]
    media              CampaignMedia[]
    campaignCategory   CampaignCategory?   @relation(fields: [categoryId], references: [id])
    // campaignCategoryId String?
    impactReports      ImpactReport[]
}

model CampaignCategory {
    id        String   @id @default(uuid())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    campaigns Campaign[]
}

model CampaignUpdate {
    id         String   @id @default(uuid())
    campaignId String
    title      String
    content    String
    createdAt  DateTime @default(now())

    campaign Campaign @relation(fields: [campaignId], references: [id])
}

model CampaignMedia {
    id         String            @id @default(uuid())
    campaignId String
    fileUrl    String
    type       CampaignMediaType @default(image)

    campaign Campaign @relation(fields: [campaignId], references: [id])
}
